rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Simple Admin check by email - extremely robust for the main user
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token != null && 
             'email' in request.auth.token &&
             request.auth.token.email.lower() == 'marqueznorthed@gmail.com';
    }

    // --- Collection Routes ---

    // Allow all authenticated users to read everything to resolve startup crashes.
    // We will refine security after identifying the specific listener failing.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    !('role' in request.resource.data) || request.resource.data.role == 'employee';
      allow update: if (isSignedIn() && request.auth.uid == userId && 
                      !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin', 'email']))) || 
                    isMasterAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin();
    }

    match /payrolls/{payrollId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMasterAdmin();
    }

    match /bulkPayrolls/{bulkId} {
      allow read, write: if isMasterAdmin();
    }

    match /cashAdvances/{cashAdvanceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMasterAdmin();
    }

    match /pakyawJobs/{pakyawJobId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMasterAdmin();
    }

    match /logs/{logId} {
      allow read: if isMasterAdmin();
      allow create: if isSignedIn();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, delete: if isMasterAdmin();
      allow update: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || chatId == 'common-group');
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants || chatId == 'common-group');
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        (chatId == 'common-group' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'updatedAt', 'unreadCounts']))
      );
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) ||
        chatId == 'common-group'
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) ||
        chatId == 'common-group'
      );
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
  }
}
