{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Admin or Employee)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "employeeId": { "type": "string", "description": "Linked employee record ID for employee role" }
      },
      "required": ["email", "role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee record",
      "type": "object",
      "properties": {
        "customId": { "type": "string" },
        "fullName": { "type": "string" },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "dailySalary": { "type": "number" },
        "hourlyRate": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["fullName", "dailySalary", "hourlyRate", "createdAt", "uid"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record for an employee",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timeIn": { "type": "string" },
        "timeOut": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "pakyaw"] },
        "regularHours": { "type": "number" },
        "otHours": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "date", "status", "createdAt", "uid"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Payroll record for an employee for a specific period",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "totalPresent": { "type": "number" },
        "totalAbsent": { "type": "number" },
        "absentDates": {
          "type": "array",
          "items": { "type": "string", "format": "date" }
        },
        "totalRegularHours": { "type": "number" },
        "totalOtHours": { "type": "number" },
        "regularPay": { "type": "number" },
        "otPay": { "type": "number" },
        "cashAdvanceDeduction": { "type": "number" },
        "totalPay": { "type": "number" },
        "bulkId": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "startDate", "endDate", "totalPresent", "totalAbsent", "absentDates", "totalRegularHours", "totalOtHours", "regularPay", "otPay", "totalPay", "createdAt", "uid"]
    },
    "BulkPayroll": {
      "title": "Bulk Payroll",
      "description": "A record representing a bulk payroll generation run",
      "type": "object",
      "properties": {
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["startDate", "endDate", "generatedAt", "userId"]
    },
    "CashAdvance": {
      "title": "Cash Advance",
      "description": "Cash advance record for an employee",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "date", "amount", "createdAt", "uid"]
    },
    "PakyawJob": {
      "title": "Pakyaw Job",
      "description": "Piece-rate contract for a job split among employees",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "totalPrice": { "type": "number" },
        "employeeIds": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["description", "startDate", "totalPrice", "employeeIds", "createdAt", "uid"]
    },
    "Log": {
      "title": "Log",
      "description": "System log or error record",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "level": { "type": "string", "enum": ["info", "error"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["message", "level", "createdAt", "uid"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "System-wide announcement posted by an admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "postedBy": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "viewedBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["title", "message", "postedBy", "authorName", "createdAt", "expiresAt", "viewedBy", "priority"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users or a group chat",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["group", "direct"] },
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "lastSenderId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "type", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "file"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "senderName", "text", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Admin users"
    },
    "/employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Employee records"
    },
    "/attendance/{attendanceId}": {
      "schema": { "$ref": "#/entities/Attendance" },
      "description": "Attendance records"
    },
    "/payrolls/{payrollId}": {
      "schema": { "$ref": "#/entities/Payroll" },
      "description": "Payroll records"
    },
    "/bulkPayrolls/{bulkId}": {
      "schema": { "$ref": "#/entities/BulkPayroll" },
      "description": "Bulk payroll generation runs"
    },
    "/cashAdvances/{cashAdvanceId}": {
      "schema": { "$ref": "#/entities/CashAdvance" },
      "description": "Cash advance records"
    },
    "/pakyawJobs/{pakyawJobId}": {
      "schema": { "$ref": "#/entities/PakyawJob" },
      "description": "Piece-rate contract records"
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "System logs"
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Corporate announcements"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Direct and group conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages belonging to a chat"
    }
  }
}